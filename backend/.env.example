DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/jobrec
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
SBERT_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIM=384
RETRAIN_THRESHOLD=100
MODEL_CHECKPOINT_DIR=ml_checkpoints/
MAX_UPLOAD_SIZE_MB=10
SEED_DATA_PATH=data/training_data.csv

# ── Crawler Settings ──────────────────────────────────────────────────────────
CRAWLER_INTERVAL_MINUTES=10         # How often to crawl (minutes)
CRAWLER_MAX_JOBS_PER_RUN=30         # Max new jobs to process per run
CRAWLER_PAGES_PER_RUN=2             # Number of listing pages to crawl
CRAWLER_REQUEST_DELAY=1.5           # Seconds between HTTP requests (politeness)
CRAWLER_MAX_RETRIES=3               # Max retries on failed requests
CRAWLER_BACKOFF_FACTOR=2.0          # Exponential backoff multiplier
CRAWLER_TIMEOUT=15                  # HTTP request timeout (seconds)
CRAWLER_EMBED_ON_INSERT=true        # Generate SBERT embedding on insert
ITVIEC_BASE_URL=https://itviec.com  # ITviec base URL
ITVIEC_JOBS_PATH=/it-jobs           # ITviec jobs listing path
